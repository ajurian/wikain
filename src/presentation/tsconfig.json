{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "types": ["node", "vite/client"],
    "baseUrl": ".",
    // `@/*` is the shadcn alias (presentation-local, pinned by components.json).
    // `~/*` reaches the other layers from here — baseUrl is src/presentation, so `../*` is src/*.
    "paths": { "@/*": ["./*"], "~/*": ["../*"] }
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
