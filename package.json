{
  "name": "wikain",
  "version": "0.0.0",
  "private": true,
  "description": "Wikain — multi-user web English active-vocabulary trainer (cloud judge, online). Build-time content generation pipeline + v4 runtime.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "typecheck:web": "tsc -p src/presentation/tsconfig.json --noEmit",
    "dev": "vite dev",
    "build": "vite build",
    "start": "node dist/server/server.js",
    "stageA": "tsx build/stageA.ts",
    "feed": "tsx build/stageB.ts feed",
    "ingest": "tsx build/stageB.ts ingest",
    "validate": "tsx build/stageC.ts",
    "combine": "tsx build/combine.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "csv-parse": "^7.0.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^7.3.6",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@neondatabase/serverless": "^1.1.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "@tanstack/react-start": "^1.168.27",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "ts-fsrs": "^4.6.1",
    "wink-eng-lite-web-model": "^1.8.0",
    "wink-nlp": "^2.3.2"
  }
}
